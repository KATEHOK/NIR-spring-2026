# Server
SERVER_PORT=8000
SERVER_IP=0.0.0.0
SERVER_CORS=http://localhost:8000,http://127.0.0.1:8000
FAULT_LIMIT=3
FAULT_LIMIT_UPDATE_PERIOD=60
BAN_PERIOD=1440

# DB
DB_NAME=auth_db
DB_HOST=db
DB_PORT=5432
DB_USER=auth_user

# JWT
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=1
REFRESH_TOKEN_EXPIRE_MINUTES=2
FAST_REFRESH_TOKEN_EXPIRE_MINUTES=1

# Development
DB_PASSWORD_FILE=C:/Inst/4_course/8_sem_2/NIR/server/app/.secrets/db_password
SECRET_KEY_FILE=C:/Inst/4_course/8_sem_2/NIR/server/app/.secrets/secret_key
JWT_PUBLIC_KEY_FILE=C:/Inst/4_course/8_sem_2/NIR/server/app/.secrets/jwt_public_key.pem
JWT_PRIVATE_KEY_FILE=C:/Inst/4_course/8_sem_2/NIR/server/app/.secrets/jwt_private_key.pem