<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://sche.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/otp_title"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp" />

    <EditText
        android:id="@+id/editTextChallenge"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/challenge_hint"
        android:inputType="text"
        android:layout_marginBottom="16dp"
        android:autofillHints=""
        tools:ignore="Autofill" />

    <Button
        android:id="@+id/buttonGenerateOtp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/generate_otp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/textViewOtpResult"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="18sp"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/buttonCopyOtp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/copy_otp"
        android:layout_marginBottom="16dp"
        android:visibility="gone" />

    <ProgressBar
        android:id="@+id/progressBarOtp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:id="@+id/actionButtonsLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone"
        android:layout_marginBottom="16dp">

        <Button
            style="?android:attr/buttonBarButtonStyle"
            android:id="@+id/buttonConfirmLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/confirm_login"
            android:layout_marginEnd="8dp" />

        <Button
            style="?android:attr/buttonBarButtonStyle"
            android:id="@+id/buttonCancelLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cancel_login" />
    </LinearLayout>

    <Button
        android:id="@+id/buttonReset"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/reset_token"
        android:textColor="@android:color/white"
        android:backgroundTint="@android:color/holo_red_dark" />

</LinearLayout>